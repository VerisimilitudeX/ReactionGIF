import Foundation

// TEMPLATE. Copy this file to `Secrets.swift` (same folder) and fill in your keys.
//   cp Shared/Secrets.swift.example Shared/Secrets.swift
// `Secrets.swift` is git-ignored so your real keys never get committed.
// This .example file is NOT compiled (its name does not end in .swift).

/// API keys live here. Fill them in before running.
enum Secrets {
    /// https://platform.openai.com/api-keys
    static let openAIAPIKey = ""

    /// https://developers.google.com/tenor/guides/quickstart
    static let tenorAPIKey = ""

    /// https://developers.giphy.com/dashboard/
    static let giphyAPIKey = ""
}

enum AppConfig {
    /// Your deployed backend proxy (see the `Backend/` folder). When set, ALL
    /// OpenAI/Tenor/Giphy calls go through it and NO API keys ship in the app.
    /// Leave empty to call the providers directly with the keys above (dev only).
    static let backendBaseURL = ""

    /// Public URL of your privacy policy (required for App Store Connect).
    static let privacyPolicyURL = ""

    /// The OpenAI model used to read the screenshot and pick reactions.
    static let openAIModel = "gpt-4o"

    /// Tenor recommends a stable per-app client key for analytics/rate limiting.
    static let tenorClientKey = "reactiongif_ios"

    /// How many candidates to pull from each provider per search.
    static let resultLimit = 10

    // MARK: Content moderation
    /// Tenor content filter: off | low | medium | high (high = G/PG only).
    static let tenorContentFilter = "medium"

    /// Giphy rating: g | pg | pg-13 | r.
    static let giphyRating = "pg-13"
}
